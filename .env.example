# CatieAPI service port.
PORT=8787

# Frontend static files. In the Docker image this should be /app/dist.
STATIC_DIR=dist

# Browser origin allowed to call the API with cookies.
CORS_ORIGIN=http://localhost:5173

# Optional admin fallback token for management APIs.
ADMIN_TOKEN=

# Secret used to encrypt channel upstream keys at rest. Do not rotate casually.
SECRET_KEY=

# Login session lifetime in hours.
SESSION_TTL_HOURS=168

# Per-key request limit per minute.
REQUEST_LIMIT_PER_MINUTE=60

# Storage mode: file, memory, or postgres.
PERSISTENCE=file

# File storage path when PERSISTENCE=file.
DATA_FILE=data/state.json

# Postgres connection string when PERSISTENCE=postgres.
DATABASE_URL=postgres://catieapi:catieapi@localhost:5432/catieapi?sslmode=disable
DATABASE_MAX_OPEN_CONNS=10
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME_MINUTES=30

# ChatGPT web reverse proxy. Prefer configuring this in the admin console under
# Settings -> 网页反代 (it is stored and applied without a restart). These env
# vars are only a one-time bootstrap: on first start they are migrated into the
# saved settings. Leave empty to manage entirely from the admin console.
GPT_WEB_PROXY_PORT=
GPT_WEB_PROXY_TOKEN=

# Provider mode: mock or compatible.
PROVIDER_MODE=mock

# Global fallback upstream key. Prefer channel-level keys in the admin console.
UPSTREAM_API_KEY=
UPSTREAM_TIMEOUT_SECONDS=600

# Frontend URL to redirect after successful Discord login.
AUTH_SUCCESS_URL=http://localhost:5173/

# Optional Discord OAuth fallback. Prefer configuring Discord in the admin settings page.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8787/api/auth/discord/callback
DISCORD_ALLOWED_GUILD_ID=
DISCORD_ALLOWED_ROLE_ID=
